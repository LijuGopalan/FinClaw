# Environment Variables for FinClaw Financial Assistant
# =========================================================
# INSTRUCTIONS:
# 1. Copy this file to .env  →  cp .env.example .env
# 2. Fill in your actual API keys in .env
# 3. NEVER commit .env to version control
# =========================================================

# ---- LLM PROVIDERS (choose one or both) ----

# Anthropic Claude — https://console.anthropic.com/
# Recommended plan: Claude API — pay-as-you-go
# Sonnet 4.5: ~$3/MTok input, $15/MTok output
# Haiku 3.5:  ~$0.80/MTok input, $4/MTok output
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI GPT — https://platform.openai.com/
# Recommended plan: Pay-as-you-go (no subscription needed)
# GPT-5.4: pricing varies — check dashboard
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini — https://aistudio.google.com/
# Recommended plan: Pay-as-you-go
# Gemini 3 Flash Preview: ~$0.075/MTok input, $0.30/MTok output
GOOGLE_API_KEY=your_google_api_key_here

# ---- FINANCIAL DATA APIS ----

# Alpha Vantage — https://www.alphavantage.co/support/#api-key
# Free: 25 calls/day | Premium: $50/month (options + fundamentals)
# RECOMMENDATION: Start free, upgrade to Premium if you need options data
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# Tradier — https://developer.tradier.com/
# FREE with a funded brokerage account (best deal for options data!)
# Sign up at tradier.com → open account → get API key from developer portal
TRADIER_API_KEY=your_tradier_key_here

# Polygon.io — https://polygon.io/
# Options data: $79/month Starter plan
# Best for: high-quality, real-time options chains
POLYGON_API_KEY=your_polygon_key_here

# ---- NEWS ----

# NewsAPI — https://newsapi.org/
# Free: 100 requests/day (developer plan)
# Paid: $449/month for production
NEWS_API_KEY=your_newsapi_key_here

# ---- NOTIFICATIONS ----

# Telegram Bot — https://t.me/BotFather
# 1. Message @BotFather on Telegram
# 2. Create a new bot, get token
# 3. Start a chat with your bot, get your chat_id
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Email (Gmail SMTP)
# Use an App Password (not your real Gmail password)
# Enable at: https://myaccount.google.com/apppasswords
EMAIL_FROM=your_email@gmail.com
EMAIL_TO=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password_here

# Slack Webhook
SLACK_WEBHOOK_URL=your_slack_webhook_url_here
